PORT=4000
NODE_ENV=development
# Produção: defina NODE_ENV=production no painel do host (Render/Railway costuma fazer isso).
JWT_SECRET=altere-para-uma-string-longa-e-aleatoria-em-producao
CLIENT_ORIGIN=http://localhost:5173
# Produção: URL(s) do front no navegador (vírgula se várias). Alternativa: CORS_ORIGIN.
# CLIENT_ORIGIN=https://meu-app.vercel.app,http://localhost:5173

# Opcional: caminho do SQLite (absoluto ou relativo ao cwd do processo). Use volume persistente no host.
# SQLITE_PATH=/data/app.db

# Opcional: interface de escuta (padrão 0.0.0.0 — necessário na maioria dos PaaS).
# HOST=0.0.0.0
